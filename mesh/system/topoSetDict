FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(
    // Select all boundary faces at z=0 (symmetry plane)
    {
        name    symmetryFaces;
        type    faceSet;
        action  new;
        source  boundaryToFace;
    }
    {
        name    symmetryFaces;
        type    faceSet;
        action  subset;
        source  boxToFace;
        box     (-11 -11 -0.001) (11 11 0.001);
    }
);

