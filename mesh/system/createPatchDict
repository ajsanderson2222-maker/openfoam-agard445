FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      createPatchDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

pointSync false;

patches
(
    {
        name        symmetry;
        patchInfo
        {
            type symmetryPlane;
        }
        constructFrom patches;
        patches ( allBoundary_0 );  // z=0 face from blockMesh
    }

    {
        name        farfield;
        patchInfo
        {
            type patch;
        }
        constructFrom patches;
        patches ( allBoundary );
    }

    {
        name redistributeHelper;
        patchInfo { type internal; }
        constructFrom patches;
        patches ();
    }
);

